{
  "functions": [
    {
      "source": "functions",
      "codebase": "default",
      "runtime": "nodejs22"
    }
  ],
  "hosting": {
    "public": "site",
    "ignore": ["firebase.json", "**/.*", "**/node_modules/**"],
    "cleanUrls": true,
    "rewrites": [
      {
        "source": "/checkout",
        "function": {
          "functionId": "checkout",
          "region": "asia-northeast3"
        }
      },
      {
        "source": "/nicepay-return",
        "function": {
          "functionId": "nicepayReturn",
          "region": "asia-northeast3"
        }
      },
      {
        "source": "/desktop-login-complete",
        "function": {
          "functionId": "desktopLoginComplete",
          "region": "asia-northeast3"
        }
      },
      {
        "source": "/desktop-login-status",
        "function": {
          "functionId": "desktopLoginStatus",
          "region": "asia-northeast3"
        }
      },
      {
        "source": "/desktop-license",
        "function": {
          "functionId": "desktopLicense",
          "region": "asia-northeast3"
        }
      },
      {
        "source": "/start-trial",
        "function": {
          "functionId": "startTrial",
          "region": "asia-northeast3"
        }
      }
    ]
  }
}
